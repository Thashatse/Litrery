<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Litrery.MainPage"
             Title="My Vehicles">

    <Grid RowDefinitions="*,Auto" Padding="16">
        
        <CollectionView x:Name="VehicleList" Grid.Row="0">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,6" Padding="16" StrokeShape="RoundRectangle 12">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding Name}" FontSize="14" TextColor="Gray"/>
                            <Label Text="{Binding Make, StringFormat='{0}'}" FontSize="18" FontAttributes="Bold"/>
                            <Label Text="{Binding Model}" FontSize="18" FontAttributes="Bold"/>
                            <Label Text="{Binding Year}" FontSize="12" TextColor="Gray"/>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <ActivityIndicator x:Name="LoadingIndicator" 
                           Grid.Row="0"
                           IsRunning="False" 
                           IsVisible="False"
                           VerticalOptions="Center"/>

        <Button Grid.Row="1" 
                Text="+ Add Vehicle" 
                Clicked="OnAddVehicleClicked"
                Margin="0,8"/>
    </Grid>

</ContentPage>